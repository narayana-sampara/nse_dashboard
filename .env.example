APP_NAME=NSE Signal Desk
APP_ENV=Production
DEBUG=0
LOG_LEVEL=INFO
CACHE_SECONDS=900
DEFAULT_PERIOD=1y
# Comma-separated browser origins. Leave empty for same-origin deployments.
CORS_ORIGINS=
# Leave these empty to use the in-memory cache and disable snapshot persistence.
REDIS_URL=
DATABASE_URL=
DEPENDENCY_TIMEOUT_SECONDS=2
# Workers use separate Redis databases for broker/result traffic in Compose.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
WORKER_SCHEDULE_SECONDS=300
WORKER_DATA_TTL_SECONDS=3600
IDEMPOTENCY_TTL_SECONDS=86400
# Weekly predictions run at 16:00 Asia/Kolkata on weekdays. API defaults are
# no price restriction, probability >=60%, expected return >=2%, traded value >=Rs1cr.
# Monthly predictions support 1-12 month horizons and default to score >=60,
# no price restriction and traded value >=Rs1cr.
# Max seconds the API waits for on-demand prediction generation before returning latest persisted data.
PREDICTION_GENERATE_TIMEOUT_SECONDS=25
# Comma-separated bearer tokens accepted by /api/v1/stream/* WebSockets.
WEBSOCKET_TOKENS=local-development-token
WEBSOCKET_HEARTBEAT_SECONDS=30
STREAM_CHANNEL_PREFIX=nse:stream
METRICS_ENABLED=1
OTEL_SERVICE_NAME=nse-dashboard-api
# Example: http://localhost:4317 (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACE_SAMPLE_RATIO=0.1
# Secret used to sign login JWTs. Set a random 32+ byte value; required in production.
JWT_SECRET=
JWT_EXPIRES_MINUTES=480
# The administrator account is created on first API startup if a password is set here.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=NseAdmin!2026
SEED_USER1_USERNAME=Bhagavan
SEED_USER1_PASSWORD=Zefinity@2026
SEED_USER2_USERNAME=Suresh
SEED_USER2_PASSWORD=Zefinity@2026
